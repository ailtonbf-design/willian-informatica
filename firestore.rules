rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Document ID: Auto-generated
    // Fields:
    //   - nome: string (required, length 1-100) - Full name of the lead
    //   - whatsapp: string (required, length 1-20) - WhatsApp number
    //   - categoria: string (required) - Category of the lead
    //   - status: string (required) - Status (Novo, Em Atendimento, etc)
    //   - createdAt: timestamp (required) - When the lead registered
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // AVISO: Configuração insegura para protótipo. 
      // Como o login foi revertido para usuário e senha fixos no código (sem Firebase Auth),
      // as regras do banco de dados precisam permitir leitura e escrita públicas.
      return true; 
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidLead(data) {
      return hasOnlyAllowedFields(['nome', 'whatsapp', 'categoria', 'status', 'createdAt', 'notas']) &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() <= 100 &&
             data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() <= 20 &&
             data.categoria is string && data.categoria.size() > 0 && data.categoria.size() <= 100 &&
             data.status is string && data.status in ['Novo', 'Em Atendimento', 'Matriculado', 'Perdido'] &&
             data.createdAt is timestamp &&
             (!('notas' in data) || (data.notas is string && data.notas.size() <= 1000));
    }

    function isValidLeadUpdate(data) {
      return hasOnlyAllowedFields(['nome', 'whatsapp', 'categoria', 'status', 'createdAt', 'notas']) &&
             data.nome == resource.data.nome &&
             data.whatsapp == resource.data.whatsapp &&
             data.categoria == resource.data.categoria &&
             data.createdAt == resource.data.createdAt &&
             data.status is string && data.status in ['Novo', 'Em Atendimento', 'Matriculado', 'Perdido'] &&
             (!('notas' in data) || (data.notas is string && data.notas.size() <= 1000));
    }

    function isValidConfiguracao(data) {
      return hasOnlyAllowedFields(['titulo', 'descricao', 'imagemUrl']) &&
             (!('titulo' in data) || (data.titulo is string && data.titulo.size() <= 100)) &&
             (!('descricao' in data) || (data.descricao is string && data.descricao.size() <= 500)) &&
             (!('imagemUrl' in data) || (data.imagemUrl is string && data.imagemUrl.size() <= 1048576));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users collection for RBAC
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && hasOnlyAllowedFields(['role', 'email']) && request.resource.data.role == 'user';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      // Anyone can create a lead (e.g., landing page form)
      allow create: if isValidLead(request.resource.data);
      // Only admins can read, update, or delete leads
      allow read, delete: if isAdmin();
      allow update: if isAdmin() && isValidLeadUpdate(request.resource.data);
    }

    match /configuracoes/{configId} {
      // Anyone can read configurations
      allow read: if true;
      // Only admins can update configurations
      allow create, update: if isAdmin() && (
                               (configId == 'cursoDestaque' && isValidConfiguracao(request.resource.data)) ||
                               (configId == 'vagas' && hasOnlyAllowedFields(['lista']) && request.resource.data.lista is list) ||
                               (configId == 'carrossel' && hasOnlyAllowedFields(['lista']) && request.resource.data.lista is list)
                             );
      allow delete: if false;
    }

    match /cursos/{cursoId} {
      // Anyone can read courses
      allow read: if true;
      // Only admins can manage courses
      allow write: if isAdmin();
    }

    match /inscricoes_aluno_empreendedor/{inscricaoId} {
      // Anyone can create an enrollment
      allow create: if true; // In a real app, we would validate the data
      // Only admins can read or manage enrollments
      allow read, write: if isAdmin();
    }

    match /leads_empreendedor/{leadId} {
      // Anyone can create a lead
      allow create: if true; // We should validate, but for now allow creation
      // Only admins can read or manage
      allow read, write: if isAdmin();
    }
  }
}
